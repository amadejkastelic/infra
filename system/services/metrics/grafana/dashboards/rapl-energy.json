{
  "uid": "rapl-energy",
  "title": "Power & Energy (CPU + GPU)",
  "description": "Host power & energy: Intel CPU (RAPL, joule counter) + NVIDIA dGPU (nvidia_smi_power_draw_watts via prometheus-nvidia-gpu-exporter). Focus on instantaneous power draw (W) and derived energy.",
  "tags": ["energy", "rapl", "nvidia"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 6,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(node_rapl_energy_joules, hostname)",
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Package Power",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (rate(node_rapl_energy_joules{hostname=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "{{hostname}}"
        }
      ],
      "description": "Broadest Intel RAPL domain (psys) - CPU package + iGPU + DRAM.",
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU Power Draw",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nvidia_smi_power_draw_watts{hostname=~\"$host\"}",
          "legendFormat": "{{hostname}}"
        }
      ],
      "description": "NVIDIA dGPU instantaneous power draw (nvidia-smi).",
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 120
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Total Power (CPU + GPU)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (rate(node_rapl_energy_joules{hostname=~\"$host\"}[$__rate_interval])) + on (hostname) group_left() nvidia_smi_power_draw_watts{hostname=~\"$host\"}",
          "legendFormat": "{{hostname}}"
        }
      ],
      "description": "CPU package + dGPU. Only shown for hosts with a GPU.",
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 180
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU Energy Today",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (increase(node_rapl_energy_joules{hostname=~\"$host\"}[24h])) / 3.6e6",
          "legendFormat": "{{hostname}}"
        }
      ],
      "description": "CPU-package energy only (RAPL). Low until the counter accumulates uptime.",
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Energy Cost Today",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (increase(node_rapl_energy_joules{hostname=~\"$host\"}[24h])) / 3.6e6 * 0.13",
          "legendFormat": "{{hostname}}"
        }
      ],
      "description": "CPU-package energy @ 0.13 EUR/kWh. Excludes dGPU.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "yellow"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Est. Monthly Cost",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (increase(node_rapl_energy_joules{hostname=~\"$host\"}[24h])) / 3.6e6 * 0.13 * 30",
          "legendFormat": "{{hostname}}"
        }
      ],
      "description": "Rough projection: today's CPU-package usage x 30 days @ 0.13 EUR/kWh.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Power Draw: CPU + GPU",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (rate(node_rapl_energy_joules{hostname=~\"$host\", package=\"psys\"}[$__rate_interval]))",
          "legendFormat": "{{hostname}} CPU"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nvidia_smi_power_draw_watts{hostname=~\"$host\"}",
          "legendFormat": "{{hostname}} GPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Power Breakdown (non-overlapping)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_rapl_energy_joules{hostname=~\"$host\", package!~\"psys|package-0\"}[$__rate_interval])",
          "legendFormat": "{{hostname}} - {{package}}"
        }
      ],
      "description": "core + uncore + dram (excludes aggregate psys/package-0 to avoid double counting).",
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "CPU Energy Share by Domain (7d)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (package) (increase(node_rapl_energy_joules{hostname=~\"$host\", package!~\"psys|package-0\"}[7d])) / 3.6e6",
          "legendFormat": "{{package}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value"]
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Hourly Energy Consumption (CPU + GPU)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (hostname) (increase(node_rapl_energy_joules{hostname=~\"$host\"}[1h])) / 3.6e6",
          "legendFormat": "{{hostname}} CPU"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg_over_time(nvidia_smi_power_draw_watts{hostname=~\"$host\"}[1h]) / 1000",
          "legendFormat": "{{hostname}} GPU"
        }
      ],
      "description": "CPU via RAPL increase; GPU via avg power x 1h (approx kWh).",
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 70,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
