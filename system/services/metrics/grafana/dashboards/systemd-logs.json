{
  "uid": "systemd-logs",
  "title": "Systemd Logs",
  "tags": ["logs", "systemd"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "hostname",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(hostname)",
        "refresh": 1,
        "sort": 1,
        "allValue": ".+",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "unit",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({hostname=~\"$hostname\"}, unit)",
        "refresh": 1,
        "sort": 1,
        "allValue": ".+",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log rate by unit",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (unit) (rate({hostname=~\"$hostname\", unit=~\"$unit\"} [$__interval]))",
          "legendFormat": "{{unit}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "drawStyle": "bars",
        "stacking": {
          "mode": "normal"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["sum"]
        }
      }
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Top units by volume",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(10, sum by (unit) (count_over_time({hostname=~\"$hostname\", unit=~\"$unit\"} [$__range])))",
          "legendFormat": "{{unit}}",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": true
        },
        "showUnfilled": true
      }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Volume by host",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (hostname) (count_over_time({hostname=~\"$hostname\", unit=~\"$unit\"} [$__range]))",
          "legendFormat": "{{hostname}}",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": true
        },
        "showUnfilled": true
      }
    }
  ]
}
